[Unit]
Description=Astrologist Gunicorn
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/astrologist
Environment="PATH=/usr/bin:/usr/local/bin"
Environment="DEEPSEEK_API_KEY=sk-YOUR_KEY"
Environment="DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic"
Environment="AUTH_TOKEN=YOUR_TOKEN"
ExecStart=/usr/local/bin/gunicorn -w 2 -b 127.0.0.1:8000 server:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
